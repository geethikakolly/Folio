    "@mui/icons-material": "^5.14.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "react-hook-form": "^7.45.0",
    "zod": "^3.22.0",
    "@hookform/resolvers": "^3.1.0",
    "@opentelemetry/api": "^1.5.1",
    "@opentelemetry/sdk-trace-web": "^1.13.0",
